---
import StudyPageComponent from '../../components/StudyPage.astro';
import { getStudyPage, currentYear } from '../../utils/content';
import type { Lang } from '../../utils/i18n';
import { languages } from '../../utils/i18n';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const data = await getStudyPage(lang, currentYear);

if (!data) {
  return Astro.redirect('/de/', 302);
}
---

<StudyPageComponent data={data} lang={lang} isCurrentYear />
