---
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';

interface Props {
  lang: Lang;
  title: string;
  year: number;
  reportUrl: string;
  mediaPackageUrl?: string;
  heroImage: string;
}

const { lang, title, year, reportUrl, mediaPackageUrl, heroImage } =
  Astro.props;


// Split title into lines:
// DE: "Schweizer" / "Familien" / "barometer" (italic)
// FR: "Baromètre suisse" / "des familles" (italic for "des familles" part not needed, all coral)
// IT: "Barometro svizzero" / "delle famiglie"
// The word containing "barometer/baromètre/barometro" gets split to show the meter-part in italic
const titleLines: { text: string; italic?: boolean }[] = (() => {
  if (lang === 'de') {
    return [
      { text: 'Schweizer' },
      { text: 'Familien' },
      { text: 'barometer', italic: true },
    ];
  } else if (lang === 'fr') {
    return [
      { text: 'Baromètre suisse' },
      { text: 'des familles', italic: true },
    ];
  } else {
    return [
      { text: 'Barometro svizzero' },
      { text: 'delle famiglie', italic: true },
    ];
  }
})();
---

<section class="hero section--dark">
  <!-- Coral top bar -->
  <div class="hero__topbar"></div>

  <div class="hero__content container">
    <h1 class="heading-1">
      {titleLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line.italic ? <span class="heading-1__italic">{line.text}</span> : line.text}
        </>
      ))}
    </h1>
    <div class="hero__subtitle">
      <hr class="hr--white" />
      <span class="hero__year">{year}</span>
      <hr class="hr--white" />
    </div>
    <div class="hero__actions">
      <a href={reportUrl} class="btn" target="_blank" rel="noopener">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        {t(lang, 'header.report')}
      </a>
      {
        mediaPackageUrl && (
          <a href={mediaPackageUrl} class="btn" target="_blank" rel="noopener">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            {t(lang, 'header.mediaPackage')}
          </a>
        )
      }
    </div>
  </div>

  <!-- Full-width hero image with coral band -->
  <div class="hero__image-wrapper">
    <div class="hero__image-dark"></div>
    <div class="hero__image-coral"></div>
    <div class="hero__image-container">
      <img src={heroImage} alt="Illustration einer Familie" width="1140" height="400" loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
  }

  .hero__topbar {
    height: 6px;
    background-color: var(--color-coral);
  }

  .hero__content {
    text-align: center;
    padding-top: 6rem;
    padding-bottom: var(--spacing-lg);
  }

  .hero__subtitle {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-block: var(--spacing-md);
    max-width: 600px;
    margin-inline: auto;
  }

  .hero__subtitle hr {
    flex: 1;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.4);
  }

  .hero__year {
    font-size: 1.25rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-bottom: var(--spacing-md);
  }

  .hero__image-wrapper {
    position: relative;
    width: 100%;
  }

  .hero__image-dark {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background-color: var(--color-dark-blue);
  }

  .hero__image-coral {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background-color: var(--color-coral);
  }

  .hero__image-container {
    position: relative;
    max-width: var(--container-max-width);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .hero__image-container img {
    width: 100%;
    height: auto;
    display: block;
  }

</style>
