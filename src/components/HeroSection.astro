---
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';

interface Props {
  lang: Lang;
  title: string;
  year: number;
  reportUrl: string;
  mediaPackageUrl?: string;
  heroImage: string;
}

const { lang, title, year, reportUrl, mediaPackageUrl, heroImage } =
  Astro.props;

const shareUrl = `https://familienbarometer.ch/${lang}`;
const shareText = encodeURIComponent(title);

// Split title for styling: "Schweizer Familien" in coral bold, "barometer" in coral italic
const titleParts = title.split(/(?=barometer|baromètre|barometro)/i);
const mainTitle = titleParts[0]?.trim() || title;
const italicPart = titleParts[1]?.trim() || '';
---

<section class="hero section--dark">
  <!-- Coral top bar -->
  <div class="hero__topbar"></div>

  <div class="hero__content container">
    <h1 class="heading-1">
      {mainTitle}<br />
      {italicPart && <span class="heading-1__italic">{italicPart}</span>}
    </h1>
    <div class="hero__subtitle">
      <hr class="hr--white" />
      <span class="hero__year">{year}</span>
      <hr class="hr--white" />
    </div>
    <div class="hero__actions">
      <a href={reportUrl} class="btn" target="_blank" rel="noopener">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        {t(lang, 'header.report')}
      </a>
      {
        mediaPackageUrl && (
          <a href={mediaPackageUrl} class="btn" target="_blank" rel="noopener">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            {t(lang, 'header.mediaPackage')}
          </a>
        )
      }
    </div>
    <div class="social-links">
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
        target="_blank"
        rel="noopener"
        aria-label="Share on LinkedIn"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
      <a
        href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareText}`}
        target="_blank"
        rel="noopener"
        aria-label="Share on X"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
      </a>
      <a
        href={`mailto:?subject=${shareText}&body=${shareUrl}`}
        aria-label="Share via email"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            stroke="currentColor"
            stroke-width="2"></path>
          <path
            d="M22 6l-10 7L2 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Full-width hero image with coral band -->
  <div class="hero__image-wrapper">
    <div class="hero__image-dark"></div>
    <div class="hero__image-coral"></div>
    <div class="hero__image-container">
      <img src={heroImage} alt="" width="1140" height="400" loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
  }

  .hero__topbar {
    height: 6px;
    background-color: var(--color-coral);
  }

  .hero__content {
    text-align: center;
    padding-top: 6rem;
    padding-bottom: var(--spacing-lg);
  }

  .hero__subtitle {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-block: var(--spacing-md);
    max-width: 600px;
    margin-inline: auto;
  }

  .hero__subtitle hr {
    flex: 1;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.4);
  }

  .hero__year {
    font-size: 1.25rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-bottom: var(--spacing-md);
  }

  .hero__image-wrapper {
    position: relative;
    width: 100%;
  }

  .hero__image-dark {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background-color: var(--color-dark-blue);
  }

  .hero__image-coral {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background-color: var(--color-coral);
  }

  .hero__image-container {
    position: relative;
    max-width: var(--container-max-width);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .hero__image-container img {
    width: 100%;
    height: auto;
    display: block;
  }

  .social-links {
    justify-content: center;
  }
</style>
