---
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const footerData = {
  de: {
    impressumText:
      'Das Familienbarometer ist eine Initiative der Pax, Schweizerische Lebensversicherungs-Gesellschaft AG, und Pro Familia Schweiz. Die Studie wird durchgeführt von Empiricon AG.',

    copyright:
      '© Pro Familia Schweiz | Pax, Schweizerische Lebensversicherungs-Gesellschaft AG',
    privacyUrl: 'https://www.pax.ch/de/rechtliches/datenschutzerklaerung/',
    legalUrl: 'https://www.pax.ch/de/rechtliches/',
  },
  fr: {
    impressumText:
      "Le Baromètre des familles est une initiative de Pax, Société suisse d'assurance sur la vie SA, et de Pro Familia Suisse. L'étude est réalisée par Empiricon AG.",
    copyright:
      "© Pro Familia Suisse | Pax, Société suisse d'assurance sur la vie SA",
    privacyUrl:
      'https://www.pax.ch/fr/informations-juridiques/declaration-de-protection-des-donnees/',
    legalUrl: 'https://www.pax.ch/fr/informations-juridiques/',
  },
  it: {
    impressumText:
      "Il Barometro delle famiglie è un'iniziativa di Pax, Società svizzera di assicurazione sulla vita SA, e di Pro Familia Svizzera. Lo studio è realizzato da Empiricon AG.",
    copyright:
      '© Pro Familia Svizzera | Pax, Società svizzera di assicurazione sulla vita SA',
    privacyUrl:
      'https://www.pax.ch/it/note-legali/dichiarazione-sulla-protezione-dei-dati/',
    legalUrl: 'https://www.pax.ch/it/note-legali/',
  },
};

const data = footerData[lang];
---

<footer class="footer section section--dark">
  <div class="container">
    <hr class="hr" />
    <div class="footer-cols">
      <div class="footer-col">
        <h3 class="footer-col__heading">{t(lang, 'footer.impressum')}</h3>
        <p>{data.impressumText}</p>
      </div>
      <div class="footer-col">
        <h3 class="footer-col__heading">{t(lang, 'footer.initiators')}</h3>
        <p>
          <a href={`https://www.pax.ch/${lang}/`} target="_blank" rel="noopener"
            >Pax</a
          >
        </p>
        <p>
          <a href="https://www.profamilia.ch/" target="_blank" rel="noopener"
            >Pro Familia Schweiz</a
          >
        </p>
      </div>
      <div class="footer-col">
        <h3 class="footer-col__heading">
          {t(lang, 'footer.collaboration')}
        </h3>
        <p>
          <a href="https://www.empiricon.ch/" target="_blank" rel="noopener"
            >Empiricon AG</a
          >
        </p>
      </div>
    </div>
    <hr class="hr" />
    <div class="footer-bottom">
      <span>{data.copyright}</span>
      <div class="footer-bottom__links">
        <a href={data.privacyUrl} target="_blank" rel="noopener">
          {t(lang, 'footer.privacy')}
        </a>
        <a href={`/${lang}/impressum`}>
          {t(lang, 'footer.impressum')}
        </a>
        <a href={data.legalUrl} target="_blank" rel="noopener">
          {t(lang, 'footer.legal')}
        </a>
      </div>
    </div>
  </div>
</footer>
