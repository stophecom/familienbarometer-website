---
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const footerData = {
  de: {
    infoHeading: 'Info',
    impressumText:
      'Das Familienbarometer ist eine Initiative der Pax, Schweizerische Lebensversicherungs-Gesellschaft AG, und Pro Familia Schweiz. Die Studie wird durchgeführt von Empiricon AG.',
    copyright:
      '© Pro Familia Schweiz | Pax, Schweizerische Lebensversicherungs-Gesellschaft AG',
  },
  fr: {
    infoHeading: 'Info',
    impressumText:
      "Le Baromètre des familles est une initiative de Pax, Société suisse d'assurance sur la vie SA, et de Pro Familia Suisse. L'étude est réalisée par Empiricon AG.",
    copyright:
      "© Pro Familia Suisse | Pax, Société suisse d'assurance sur la vie SA",
  },
  it: {
    infoHeading: 'Info',
    impressumText:
      "Il Barometro delle famiglie è un'iniziativa di Pax, Società svizzera di assicurazione sulla vita SA, e di Pro Familia Svizzera. Lo studio è realizzato da Empiricon AG.",
    copyright:
      '© Pro Familia Svizzera | Pax, Società svizzera di assicurazione sulla vita SA',
  },
};

const data = footerData[lang];

const shareUrl = `https://familienbarometer.ch/${lang}`;
const shareText = encodeURIComponent(
  lang === 'de'
    ? 'Schweizer Familienbarometer'
    : lang === 'fr'
      ? 'Baromètre suisse des familles'
      : 'Barometro svizzero delle famiglie',
);
---

<footer class="footer section section--dark" role="contentinfo">
  <div class="container">
    <div class="social-links">
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
        target="_blank"
        rel="noopener"
        aria-label="Share on LinkedIn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
      </a>
      <a
        href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareText}`}
        target="_blank"
        rel="noopener"
        aria-label="Share on X"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
        </svg>
      </a>
      <a
        href={`mailto:?subject=${shareText}&body=${shareUrl}`}
        aria-label="Share via email"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2"></path>
          <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </a>
    </div>
    <hr class="hr" />
    <div class="footer-cols">
      <div class="footer-col">
        <h3 class="footer-col__heading">{data.infoHeading}</h3>
        <p>{data.impressumText}</p>
      </div>
      <div class="footer-col">
        <h3 class="footer-col__heading">{t(lang, 'footer.initiators')}</h3>
        <p>
          <a href={`https://www.pax.ch/${lang}/`} target="_blank" rel="noopener"
            >Pax</a
          >
        </p>
        <p>
          <a href="https://www.profamilia.ch/" target="_blank" rel="noopener"
            >Pro Familia Schweiz</a
          >
        </p>
      </div>
      <div class="footer-col">
        <h3 class="footer-col__heading">
          {t(lang, 'footer.collaboration')}
        </h3>
        <p>
          <a href="https://www.empiricon.ch/" target="_blank" rel="noopener"
            >Empiricon AG</a
          >
        </p>
      </div>
    </div>
    <hr class="hr" />
    <div class="footer-bottom">
      <span>{data.copyright}</span>
      <div class="footer-bottom__links">
        <a href={`/${lang}/datenschutz`}>
          {t(lang, 'footer.privacy')}
        </a>
        <a href={`/${lang}/impressum`}>
          {t(lang, 'footer.impressum')}
        </a>
        <a href={`/${lang}/rechtliche-hinweise`}>
          {t(lang, 'footer.legal')}
        </a>
      </div>
    </div>
  </div>
</footer>
